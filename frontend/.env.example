# Frontend (Vite) environment variables
# Local: copy to `.env.local` (gitignored). Prod: set these in the Vercel
# dashboard (Project → Settings → Environment Variables). Vite only exposes
# VITE_-prefixed vars to the client, read via `import.meta.env`.

# Firebase Web API key — the only Firebase value read from env (the rest of the
# config is in src/lib/firebase.js; those values are public-by-design). Restrict
# this key in Google Cloud Console (HTTP referrer + API restrictions) before launch.
VITE_API_KEY=

# Express backend base URL. USED by the client (verse engine, AI recommend,
# userchats sync). Local: http://localhost:8001 — Prod: your Render URL, e.g.
# https://2gather-backend.onrender.com
VITE_API_URL=http://localhost:8001

# Push notifications (Phase 5). Web Push certificate key pair from Firebase
# Console → Project settings → Cloud Messaging → Web configuration. Optional —
# without it the "Enable push" button reports it isn't configured.
# VITE_FIREBASE_VAPID_KEY=

# --- Observability (optional — off unless set) ---
# Sentry error tracking (frontend). Set the DSN from your Sentry project.
# VITE_SENTRY_DSN=
# PostHog product analytics. Key + (optional) host from your PostHog project.
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# --- Recommended (not yet wired up) ---
# Externalize the rest of the Firebase web config instead of hardcoding it:
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=
