# Backend (Express) environment — copy to backend/.env (gitignored).
# On Render these are set in the dashboard / render.yaml, not in a file.

# Port the server listens on. Render injects PORT automatically; 8001 is the local default.
PORT=8001

# Comma-separated list of allowed CORS origins (deployed frontend + local dev).
# e.g. https://gather-bd64a.web.app,https://gather-bd64a.firebaseapp.com,http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Engagement nudges (Phase 5): set to 1 to run the hourly verse-nudge scheduler
# (sends opted-in users a daily verse, respecting quiet hours). Off by default.
# NOTE: Render's free plan sleeps on inactivity, so the scheduler won't run
# reliably there — keep 0 unless on a paid instance / external cron.
ENABLE_NUDGES=0

# Observability (optional): Sentry DSN for backend error capture. Unset = disabled.
# SENTRY_DSN=

# --- AI verse recommendations (Phase 8) — ALL OPTIONAL ---
# POST /api/verses/recommend works WITHOUT any of these (it falls back to
# keyword→theme matching). Set AI_API_KEY to let an LLM *rank* the candidate
# verses we supply — it never writes or quotes scripture itself. The provider is
# OpenAI-compatible, so it works with OpenAI, Groq, OpenRouter, etc. by swapping
# the base URL + model. The key is server-side only — never exposed to the client.
#
# OpenAI:  AI_BASE_URL=https://api.openai.com/v1       AI_MODEL=gpt-4o-mini
# Groq:    AI_BASE_URL=https://api.groq.com/openai/v1  AI_MODEL=llama-3.3-70b-versatile
# AI_PROVIDER=openai
# AI_API_KEY=
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# Cost guardrails (optional — cheap, safe defaults shown). The reply is only verse
# numbers, so each call is tiny; the real protection is capping the NUMBER of
# calls. Tune these and you can't drain an account by surprise:
#   AI_DAILY_LIMIT  max LLM calls per day; once spent, the feature falls back to
#                   keyword matching until UTC midnight. (default 200)
#   AI_MAX_RETRIES  retries on transient errors, 0-3; never loops. (default 1)
#   AI_TIMEOUT_MS   per-call timeout, 1000-30000. (default 8000)
# A bad key or exhausted quota trips a 30-min circuit breaker automatically.
# AI_DAILY_LIMIT=200
# AI_MAX_RETRIES=1
# AI_TIMEOUT_MS=8000
#
# ALSO set a hard monthly cap in the OpenAI dashboard (Settings → Limits →
# "Usage limits") — that's the ultimate backstop, independent of this app.

# --- Firebase Admin service account: choose ONE option ---
#
# Local dev: place the service-account JSON at backend/config/serviceAccount.json
#   (gitignored) and leave the two vars below UNSET.
#
# Hosted (Render) / CI: paste the ENTIRE service-account JSON as a single-line string:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"gather-bd64a","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...",...}
#
# Or point to a JSON file on disk (Google ADC standard, e.g. a Render secret file):
# GOOGLE_APPLICATION_CREDENTIALS=/etc/secrets/serviceAccount.json
